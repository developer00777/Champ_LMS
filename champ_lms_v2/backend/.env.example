# ── App ──────────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-in-production-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin bootstrap ───────────────────────────────────────────────
# The ONLY way to create an admin account — POST /auth/register always
# creates role="learner". If both are set, this account is created (or
# promoted to admin if it already exists as a learner) on every startup.
# Leave blank locally if you don't need an admin account for dev.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────────────────
# Local dev value shown (matches docker-compose.yml). In Railway, this is
# injected automatically by the MongoDB plugin as MONGO_URL — config.py
# falls back to that if MONGODB_URL isn't set explicitly.
MONGODB_URL=mongodb://dev:dev@db:27017/?authSource=admin
MONGODB_DB_NAME=champlmsv2

# ── Redis ─────────────────────────────────────────────────────────
# Local dev value shown; in Railway this is injected automatically by the
# Redis plugin (reference as ${{Redis.REDIS_URL}} in service variables).
REDIS_URL=redis://redis:6379

# ── Bunny Storage ─────────────────────────────────────────────────
# Account-level API key from bunny.net → Account → API
BUNNY_ACCOUNT_API_KEY=

# Storage zone for thumbnails
BUNNY_STORAGE_THUMBS_ZONE=champ-lms-thumbs
BUNNY_STORAGE_THUMBS_PASSWORD=

# Primary storage region hostname (e.g. storage.bunnycdn.com or la.storage.bunnycdn.com)
BUNNY_STORAGE_HOST=storage.bunnycdn.com

# ── Bunny CDN Pull Zone ───────────────────────────────────────────
# The CDN pull zone that serves thumbnails (video itself is served via Bunny Stream).
# Bunny's free b-cdn.net hostname works fine — no custom domain required.
BUNNY_CDN_HOSTNAME=champ-lms-cdn.b-cdn.net
# Token auth secret for the pull zone (Bunny → Pull Zone → Security → Token Authentication)
BUNNY_CDN_TOKEN_SECRET=

# ── Bunny Stream ──────────────────────────────────────────────────
# Stream API key (Bunny → Stream → API)
BUNNY_STREAM_API_KEY=
# Video library ID (numeric, from Bunny Stream library settings)
BUNNY_STREAM_LIBRARY_ID=
# CDN hostname for the stream library (e.g. vz-abc123.b-cdn.net) — free, no domain needed
BUNNY_STREAM_CDN_HOSTNAME=
# Token auth secret set on the Stream library (Security → Enable Token Authentication)
BUNNY_STREAM_TOKEN_SECRET=

# Webhook secret — set this as the webhook password in Bunny Stream → Webhooks
BUNNY_STREAM_WEBHOOK_SECRET=

# ── OpenRouter AI ─────────────────────────────────────────────────
# Get your key at openrouter.ai/keys (pay-as-you-go)
# Cheap defaults: google/gemini-flash-1.5, deepseek/deepseek-chat, meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

# ── Zoom ──────────────────────────────────────────────────────────
ZOOM_WEBHOOK_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated allowed origins. Frontend and backend share one Railway
# service and one origin (proxied via /api), so CORS is only relevant for
# local dev, where the SvelteKit dev server runs on a different port.
CORS_ORIGINS=http://localhost:5173
