# Copy to .env and fill in values

# App
DEBUG=true

# Database (docker-compose local)
DATABASE_URL=postgresql+asyncpg://dev:dev@db/champlms

# Redis (docker-compose local)
REDIS_URL=redis://redis:6379

# AWS — leave blank for local dev (uses dev-bypass mode)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3
S3_RAW_BUCKET=champ-lms-raw-videos
S3_HLS_BUCKET=champ-lms-hls
S3_THUMBNAILS_BUCKET=champ-lms-thumbnails

# CloudFront — leave blank for local dev
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# Cognito — leave blank for local dev (uses dev-bypass auth)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-south-1

# MediaConvert
MEDIACONVERT_ENDPOINT=
MEDIACONVERT_ROLE_ARN=

# Claude AI
ANTHROPIC_API_KEY=

# Zoom
ZOOM_WEBHOOK_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# SQS
SQS_ZOOM_QUEUE_URL=
